{
  "openapi": "3.0.1",
  "info": {
    "title": "Healthcare",
    "version": "v3"
  },
  "servers": [
    {
      "url": "http://localhost:8000"
    }
  ],
  "paths": {
    "/v1/healthcare/patients": {
      "post": {
        "tags": ["PatientService"],
        "operationId": "registerPatient",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatientRequestDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PatientResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/v1/healthcare/appointments/book/{patientId}": {
      "post": {
        "tags": ["AppointmentService"],
        "operationId": "bookAppointment",
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/AppointmentResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/v1/healthcare/appointments/{appointmentId}": {
      "get": {
        "tags": ["AppointmentService"],
        "operationId": "getAppointment",
        "parameters": [
          {
            "name": "appointmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/AppointmentResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/v1/healthcare/prescriptions/{patientId}/add": {
      "post": {
        "tags": ["PrescriptionService"],
        "operationId": "addPrescription",
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PrescriptionItemDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PrescriptionResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/v1/healthcare/prescriptions/{patientId}": {
      "get": {
        "tags": ["PrescriptionService"],
        "operationId": "getPrescriptions",
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PrescriptionResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/v1/healthcare/labs/{appointmentId}/track": {
      "get": {
        "tags": ["LabService"],
        "operationId": "trackLabReport",
        "parameters": [
          {
            "name": "appointmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LabTrackingResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/v1/healthcare/doctors": {
      "post": {
        "tags": ["DoctorService"],
        "operationId": "addDoctor",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DoctorRequestDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/DoctorResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/v1/healthcare/billing/webhook": {
      "post": {
        "tags": ["BillingService"],
        "operationId": "billingWebhook",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BillingWebhookDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BillingResponseDTO"
                }
              }
            }
          }
        }
      }
    },
    "/v1/healthcare/billing/initiate": {
      "post": {
        "tags": ["BillingService"],
        "operationId": "initiateBilling",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BillingRequestDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BillingResponseDTO"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PatientRequestDTO": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "age": { "type": "integer" },
          "gender": { "type": "string" }
        }
      },
      "PatientResponseDTO": {
        "type": "object",
        "properties": {
          "patientId": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "age": { "type": "integer" },
          "gender": { "type": "string" },
          "createdAt": { "type": "string" }
        }
      },
      "AppointmentResponseDTO": {
        "type": "object",
        "properties": {
          "appointmentId": { "type": "string" },
          "patientId": { "type": "string" },
          "doctorName": { "type": "string" },
          "appointmentDate": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "PrescriptionItemDTO": {
        "type": "object",
        "properties": {
          "medicineName": { "type": "string" },
          "dosage": { "type": "string" },
          "duration": { "type": "string" }
        }
      },
      "PrescriptionResponseDTO": {
        "type": "object",
        "properties": {
          "patientId": { "type": "string" },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PrescriptionItemDTO"
            }
          }
        }
      },
      "LabTrackingResponseDTO": {
        "type": "object",
        "properties": {
          "appointmentId": { "type": "string" },
          "labStatus": { "type": "string" },
          "reportReady": { "type": "boolean" }
        }
      },
      "DoctorRequestDTO": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "specialization": { "type": "string" },
          "experience": { "type": "integer" }
        }
      },
      "DoctorResponseDTO": {
        "type": "object",
        "properties": {
          "doctorId": { "type": "string" },
          "name": { "type": "string" },
          "specialization": { "type": "string" }
        }
      },
      "BillingRequestDTO": {
        "type": "object",
        "properties": {
          "amount": { "type": "number", "format": "double" },
          "appointmentId": { "type": "string" }
        }
      },
      "BillingResponseDTO": {
        "type": "object",
        "properties": {
          "billingId": { "type": "string" },
          "amount": { "type": "number", "format": "double" },
          "status": { "type": "string" }
        }
      },
      "BillingWebhookDTO": {
        "type": "object",
        "properties": {
          "billingId": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  }
}
